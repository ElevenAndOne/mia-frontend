# Development Environment Configuration
# Copy this file to .env and modify as needed

# API Configuration
VITE_API_BASE_URL=http://localhost:3001
VITE_ENVIRONMENT=development

# Mock Service URLs (for development)
VITE_MOCK_AUTH_URL=http://localhost:3001/mock
VITE_MOCK_DATABASE_URL=http://localhost:3001/mock/db
VITE_MOCK_GOOGLE_OAUTH_URL=http://localhost:3001/mock/auth/google
VITE_MOCK_META_OAUTH_URL=http://localhost:3001/mock/auth/meta

# Feature Flags
VITE_USE_MOCK_DATA=true
VITE_USE_MOCK_AUTH=true
VITE_ENABLE_DEVELOPMENT_TOOLS=true

# Google Services Mock
VITE_MOCK_GOOGLE_ADS_API=http://localhost:3001/mock/google-ads
VITE_MOCK_GA4_API=http://localhost:3001/mock/ga4

# Meta Services Mock  
VITE_MOCK_META_ADS_API=http://localhost:3001/mock/meta-ads
VITE_MOCK_META_GRAPH_API=http://localhost:3001/mock/meta-graph

# Development Tools
VITE_SHOW_API_LOGS=true
VITE_MOCK_DELAY_MS=500
VITE_SIMULATE_FAILURES=false

# Production URLs (use when VITE_USE_MOCK_DATA=false)
# VITE_API_BASE_URL=https://your-production-api.com
# VITE_GOOGLE_ADS_API=https://googleads.googleapis.com
# VITE_META_GRAPH_API=https://graph.facebook.com
